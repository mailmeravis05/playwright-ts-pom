{
  "compilerOptions": {
    "types": ["@types/node", "playwright"],
    "target": "ES2020",
    "module": "commonjs",
    // "types": ["node"],
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    
  
  },
  "include": ["**/*.ts", "global.d.ts", "playwright.d.ts", "fixtures.ts",],
  "exclude": ["node_modules", "dist"]
}
